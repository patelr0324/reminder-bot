TOKEN=your_discord_bot_token
# application id (discord developer portal → your app → application id)
CLIENT_ID=your_application_id

# Optional: SQLite file path (default: ./reminders.db next to database.js)
# DATABASE_PATH=./reminders.db

# Optional: if set, npm run deploy registers slash commands only in this guild (instant).
# Leave unset to register globally so commands work in every server the bot joins.
# DISCORD_GUILD_ID=
